# =============================================================
# .env.example — committed template, NOT the real .env file
# Copy to .env and fill in real values. Never commit .env.
# =============================================================

# ── CI / Test database ────────────────────────────────────────
# Used by the GitHub Actions test-backend job (postgres service).
# Set these as GitHub repository secrets: TEST_DB_PASSWORD, TEST_SECRET_KEY
TEST_DB_PASSWORD=changeme

# ── Application secrets ───────────────────────────────────────
# JWT signing key — must be a long, random string in production.
TEST_SECRET_KEY=changeme
